{
  "name": "musicology",
  "version": "0.0.0",
  "private": true,
  "description": "A local-first personal music-history laboratory",
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=9 <10"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "analyze:volume": "node src/cli/analyze-volume.ts",
    "analyze:artist-eras": "node src/cli/analyze-artist-eras.ts",
    "db:migrate": "node src/cli/db.ts migrate",
    "db:status": "node src/cli/db.ts status",
    "export:reconciliation-calibration": "node src/cli/export-reconciliation-calibration.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "import:lastfm-export": "node src/cli/import-lastfm-export.ts",
    "import:spotify": "node src/cli/import-spotify.ts",
    "lint": "biome lint .",
    "quality": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "report:coverage": "node src/cli/report-coverage.ts",
    "reconcile": "node src/cli/reconcile.ts",
    "review:decisions": "node src/cli/review-decisions.ts",
    "sync:lastfm": "node src/cli/sync-lastfm.ts",
    "test": "node --test",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "validate": "node src/cli/validate.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.13.3",
    "typescript": "7.0.2"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1"
  }
}
